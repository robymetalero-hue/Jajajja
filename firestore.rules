rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // --- Users Collection ---
    match /users/{userId} {
      allow read, write: if true;
    }

    match /usuarios/{userId} {
      allow read, write: if true;
    }

    // --- Audit & Security Logs ---
    match /security_logs/{logId} {
      allow read, write: if true;
    }

    match /system_audit_logs/{logId} {
      allow read, write: if true;
    }

    match /inventory_audit_logs/{logId} {
      allow read, write: if true;
    }

    match /exchange_rate_audit/{auditId} {
      allow read, write: if true;
    }

    // --- Core Master Data ---
    match /products/{productId} {
      allow read, write: if true;
    }

    match /departments/{departmentId} {
      allow read, write: if true;
    }

    match /settings/{settingKey} {
      allow read, write: if true;
    }

    // --- Clients ---
    match /clients/{clientId} {
      allow read, write: if true;
    }

    // --- Sales ---
    match /sales/{saleId} {
      allow read, write: if true;
    }

    match /sale_items/{itemId} {
      allow read, write: if true;
    }

    match /pending_sales/{id} {
      allow read, write: if true;
    }

    match /pending_sale_items/{id} {
      allow read, write: if true;
    }

    // --- Shifts ---
    match /shifts/{shiftId} {
      allow read, write: if true;
    }

    match /caja_cierres/{cierreId} {
      allow read, write: if true;
    }

    // --- Cash Management ---
    match /cash_accounts/{accountId} {
      allow read, write: if true;
    }

    match /cash_movements/{movementId} {
      allow read, write: if true;
    }

    match /cash_settlements/{settlementId} {
      allow read, write: if true;
    }

    // --- Financials ---
    match /accounts_receivable/{id} {
      allow read, write: if true;
    }

    match /credit_payments/{id} {
      allow read, write: if true;
    }

    match /pending_sale_payments/{id} {
      allow read, write: if true;
    }

    // --- Inventory Mgmt ---
    match /stock_arrivals/{id} {
      allow read, write: if true;
    }

    match /inventory_counts/{id} {
      allow read, write: if true;
    }

    match /inventory_count_items/{id} {
      allow read, write: if true;
    }

    // --- Connection test path ---
    match /test/{testId} {
      allow read, write: if true;
    }
  }
}

